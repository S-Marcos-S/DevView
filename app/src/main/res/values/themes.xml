        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/cyan_neon</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/purple_neon</item>
