<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_card_process"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Greeting Section -->
    <TextView
        android:id="@+id/txtWidgetGreeting"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tenha um excelente dia!"
        android:textColor="@color/cyan_neon"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Day of the Week & Date -->
    <TextView
        android:id="@+id/txtWidgetDay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quinta-feira"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_card"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <!-- Task List Header -->
    <TextView
        android:id="@+id/txtWidgetHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/widget_tasks_header"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <!-- Task Items (Simulating active tasks / processes) -->
    <LinearLayout
        android:id="@+id/layoutWidgetTasks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Task 1 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">
            <TextView
                android:id="@+id/txtWidgetTask1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Sistema Android"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/txtWidgetTask1Stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="CPU: 4%"
                android:textColor="@color/cyan_neon"
                android:textSize="11sp" />
        </RelativeLayout>

        <!-- Task 2 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">
            <TextView
                android:id="@+id/txtWidgetTask2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. WhatsApp"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/txtWidgetTask2Stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="CPU: 12%"
                android:textColor="@color/cyan_neon"
                android:textSize="11sp" />
        </RelativeLayout>

        <!-- Task 3 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/txtWidgetTask3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3. DevView"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/txtWidgetTask3Stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="CPU: 1%"
                android:textColor="@color/cyan_neon"
                android:textSize="11sp" />
        </RelativeLayout>

    </LinearLayout>

</LinearLayout>
