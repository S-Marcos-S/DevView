<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app2="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_process"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header Row (Always Visible) -->
    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/imgAppIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/sym_def_app_icon"
            android:contentDescription="Ícone do Aplicativo" />

        <LinearLayout
            android:id="@+id/layoutLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/imgAppIcon"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:layout_toStartOf="@id/layoutStatus"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nome do App"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:singleLine="true" />

            <TextView
                android:id="@+id/txtPackageName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="com.example.package"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:ellipsize="end"
                android:singleLine="true"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Status & Chevron Container -->
        <LinearLayout
            android:id="@+id/layoutStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_foreground"
                android:textColor="@color/green_neon"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/bg_status_foreground" />

            <ImageView
                android:id="@+id/imgChevron"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/arrow_down_float"
                app2:tint="@color/text_secondary"
                android:layout_marginStart="8dp" />
        </LinearLayout>

    </RelativeLayout>

    <!-- Expandable Details Area -->
    <LinearLayout
        android:id="@+id/layoutDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="16dp">

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_card"
            android:layout_marginBottom="16dp" />

        <!-- Shizuku Required Placeholder -->
        <TextView
            android:id="@+id/txtShizukuRequiredPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ Telemetria de CPU/RAM oculta (Requer Shizuku)"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="italic"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- CPU Metric -->
        <LinearLayout
            android:id="@+id/layoutCpuMetric"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_cpu"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/txtCpuValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="0%"
                    android:textColor="@color/cyan_neon"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <ProgressBar
                android:id="@+id/progressCpu"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="6dp"
                android:progress="0"
                android:max="100"
                android:progressDrawable="@android:drawable/progress_horizontal"
                android:progressBackgroundTint="@color/border_card"
                android:progressTint="@color/cyan_neon" />
        </LinearLayout>

        <!-- RAM Metric -->
        <LinearLayout
            android:id="@+id/layoutRamMetric"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_ram"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/txtRamValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="0 MB"
                    android:textColor="@color/purple_neon"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <ProgressBar
                android:id="@+id/progressRam"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="6dp"
                android:progress="0"
                android:max="100"
                android:progressDrawable="@android:drawable/progress_horizontal"
                android:progressBackgroundTint="@color/border_card"
                android:progressTint="@color/purple_neon" />
        </LinearLayout>

        <!-- Grid for Internet and Storage -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="1"
            android:alignmentMode="alignBounds"
            android:columnOrderPreserved="false"
            android:layout_marginBottom="12dp">

            <!-- Internet Column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_network"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/txtNetworkValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ 0 B/s\n↓ 0 B/s"
                    android:textColor="@color/green_neon"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Storage Column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:paddingStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_storage"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/txtStorageValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 MB"
                    android:textColor="@color/orange_neon"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

        </GridLayout>

        <!-- Source / Method label -->
        <TextView
            android:id="@+id/txtTelemetrySource"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/telemetry_simulated"
            android:textColor="@color/text_secondary"
            android:textSize="9sp"
            android:gravity="end"
            android:layout_marginTop="4dp" />

    </LinearLayout>

</LinearLayout>
